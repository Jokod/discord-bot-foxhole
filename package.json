{
	"name": "discord-foxhole-bot",
	"version": "0.9.10",
	"description": "Discord bot for Foxhole",
	"types": "./typings.d.ts",
	"main": "bot.js",
	"scripts": {
		"start": "node bot.js",
		"dev": "nodemon bot.js",
		"lint": "eslint .",
		"fix": "eslint --fix .",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"wiki:sync-materials": "node scripts/sync-wiki-materials.js",
		"wiki:sync-materials:dry": "node scripts/sync-wiki-materials.js --dry-run",
		"wiki:sync-materials:add-missing": "node scripts/sync-wiki-materials.js --add-missing-only",
		"wiki:sync-materials:add-missing:dry": "node scripts/sync-wiki-materials.js --add-missing-only --dry-run",
		"wiki:sync-materials:add-missing:and-sync": "node scripts/sync-wiki-materials.js --add-missing",
		"wiki:sync-materials:add-missing:and-sync:dry": "node scripts/sync-wiki-materials.js --add-missing --dry-run"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"mongoose": "^9.2.3"
	},
	"overrides": {
		"undici": ">=6.23.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.0.2",
		"jest": "^30.2.0"
	},
	"lint-staged": {
		"*.js": [
			"eslint --fix",
			"git add"
		]
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	}
}
