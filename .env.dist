APP_ENV=prod

PREFIX=!

TOKEN="your-bot-token"
CLIENT_ID="bot-id"

OWNER="owner-id"
TEST_GUILD_ID="dev-server-id"

MONGODB_URL="mongodb://localhost:27017"
MONGODB_NAME="foxhole-bot"

# Optional: IDs de serveurs où le bot ne doit pas rester (séparés par des virgules). Si le bot est déjà dedans, il se retire.
# BLOCKED_GUILD_IDS=123456789,987654321

# Optional: GitHub repository URL (used by /github command)
 GITHUB_URL="https://github.com/Jokod/discord-bot-foxhole"
